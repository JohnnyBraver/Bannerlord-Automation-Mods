  <!-- Post-Build Action: Copy built outputs to the Bannerlord Modules folder -->
  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <PropertyGroup>
      <ModFolder>E:\SteamLibrary\steamapps\common\Mount &amp; Blade II Bannerlord\Modules\TradeOptimizer</ModFolder>
      <ModBinFolder>$(ModFolder)\bin\Win64_Shipping_Client</ModBinFolder>
    </PropertyGroup>
    <MakeDir Directories="$(ModBinFolder)" Condition="!Exists('$(ModBinFolder)')" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="$(ModBinFolder)" />
    <Copy SourceFiles="SubModule.xml" DestinationFolder="$(ModFolder)" />
    <MakeDir Directories="$(ModFolder)\GUI\PrefabExtensions" Condition="!Exists('$(ModFolder)\GUI\PrefabExtensions')" />
    <ItemGroup>
      <GuiFiles Include="$(MSBuildProjectDirectory)\GUI\PrefabExtensions\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(GuiFiles)" DestinationFolder="$(ModFolder)\GUI\PrefabExtensions" />
  </Target>
